# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment files (real values must NEVER be committed)
.env
.env.*
!.env.example

# OS metadata
.DS_Store
Thumbs.db

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo

# Tooling caches
.dyad/

# Python (used by OmniVoice)
.venv/
__pycache__/
*.py[cod]
*$py.class

# Local secrets / runtime junk
nul

